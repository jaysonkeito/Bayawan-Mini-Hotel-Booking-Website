# ══════════════════════════════════════════════════════════════════════
#  Bayawan Mini Hotel System — Environment Configuration Template
#  ──────────────────────────────────────────────────────────────────
#  This file is safe to commit to version control.
#  To configure a new environment:
#    1. Copy this file:  cp .env.example .env
#    2. Fill in all values in .env
#    3. Never commit .env
# ══════════════════════════════════════════════════════════════════════


# ── Application ───────────────────────────────────────────────────────
# localhost : http://localhost:PORT/bayawan-mini-hotel-system
# live      : https://www.yourdomain.com   (no trailing slash)

APP_URL=http://localhost:3000/bayawan-mini-hotel-system
APP_FOLDER=bayawan-mini-hotel-system
APP_NAME=Bayawan Mini Hotel
APP_ENV=local


# ── Database ──────────────────────────────────────────────────────────

DB_HOST=localhost
DB_NAME=your_database_name
DB_USER=your_db_user
DB_PASS=your_db_password


# ── SMTP / Email ──────────────────────────────────────────────────────

SMTP_HOST=smtp.gmail.com
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM_NAME=Bayawan Mini Hotel


# ── PayMongo ──────────────────────────────────────────────────────────
# PAYMONGO_ENV: TEST or PROD
# Callback URLs are auto-built from APP_URL — do not hardcode them here.

PAYMONGO_ENV=TEST
PAYMONGO_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
PAYMONGO_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx


# ── Google OAuth ──────────────────────────────────────────────────────
# Redirect URI auto-built: {APP_URL}/ajax/user_google_callback.php
# Register that exact URL in Google Cloud Console > Authorized Redirect URIs.

GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret
