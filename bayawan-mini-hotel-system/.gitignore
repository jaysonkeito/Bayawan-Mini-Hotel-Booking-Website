# ══════════════════════════════════════════════════════════════════════
#  Bayawan Mini Hotel System — .gitignore
# ══════════════════════════════════════════════════════════════════════

# ── Environment / Secrets ─────────────────────────────────────────────
# NEVER commit the real .env file — it contains DB passwords,
# SMTP credentials, API keys, and OAuth secrets.
.env

# ── Composer / PHP dependencies ───────────────────────────────────────
# The vendor folder is generated by `composer install` and should not
# be tracked in version control.
/includes/vendor/
/vendor/

# Keep the composer files so other developers can install dependencies
!composer.json
!composer.lock

# ── Uploaded images (user-generated content) ──────────────────────────
# These are runtime files, not source code. Back them up separately.
/images/users/*
/images/rooms/*
/images/carousel/*
/images/about/*
/images/facilities/*

# Keep the folder structure with a .gitkeep in each
!/images/users/.gitkeep
!/images/rooms/.gitkeep
!/images/carousel/.gitkeep
!/images/about/.gitkeep
!/images/facilities/.gitkeep

# ── OS / Editor noise ─────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
.idea/
.vscode/
*.log
